# Variables de entorno para Backend (Render.com)
# Copiar estos valores al dashboard de Render

# Base de datos PostgreSQL
# Render creará automáticamente DATABASE_URL cuando conectes el servicio PostgreSQL
# Formato: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://admin:admin123@db:5432/tareas

# Configuración de Flask
FLASK_ENV=production
FLASK_DEBUG=False

# Puerto (Render usa el puerto de la variable PORT automáticamente)
PORT=8000

# CORS - Dominio del frontend en producción
# Ejemplo: https://tu-app.netlify.app
FRONTEND_URL=http://localhost:3000
